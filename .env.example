# ── Sicherheit ────────────────────────────────────────────────────────────────
# Gemeinsames JWT-Secret zwischen API und Web (HS256) — in Produktion ändern!
JWT_SECRET=change-me-in-production

# next-auth Session-Verschlüsselung — in Produktion ändern!
NEXTAUTH_SECRET=change-me-in-production

# ── Datenbank ─────────────────────────────────────────────────────────────────
POSTGRES_USER=eegabrechnung
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=eegabrechnung

# ── E-Mail (Rechnungsversand) ──────────────────────────────────────────────────
# SMTP-Relay für den Rechnungsversand und Onboarding-Benachrichtigungen
SMTP_HOST=mail.example.at:587
SMTP_FROM=abrechnung@meine-eeg.at
SMTP_USER=abrechnung@meine-eeg.at
SMTP_PASSWORD=
# Auf true setzen, um Rechnungen nach der Erstellung automatisch zu versenden
INVOICE_SEND_EMAIL=false

# ── Web ────────────────────────────────────────────────────────────────────────
# Öffentliche Basis-URL des Frontends — wird für Magic-Token-Links im Onboarding verwendet
WEB_BASE_URL=https://meine-eeg.at
# Öffentliche API-URL für Browser-Direktzugriff (Entwicklung/Testing; in Produktion leer lassen)
NEXT_PUBLIC_API_URL=http://localhost:8101

# ── EDA Worker ────────────────────────────────────────────────────────────────
# Transportmodus: MAIL (Produktion via EDA-E-Mail) | PONTON | FILE (lokales Testen)
EDA_TRANSPORT=MAIL

# IMAP-Postfach für eingehende MaKo-Nachrichten (Modus MAIL)
EDA_IMAP_HOST=imap.edanet.at:993
EDA_IMAP_USER=meine-eeg@edanet.at
EDA_IMAP_PASSWORD=

# SMTP für ausgehende MaKo-Nachrichten (Modus MAIL)
EDA_SMTP_HOST=smtp.edanet.at:587
EDA_SMTP_USER=meine-eeg@edanet.at
EDA_SMTP_PASSWORD=
EDA_SMTP_FROM=meine-eeg@edanet.at

# Ponton XP Outbound-Endpunkt (Modus PONTON)
EDA_PONTON_URL=http://ponton-xp:6060/ponton/eda/webservice/outbound

# Wie oft der EDA Worker nach neuen Nachrichten prüft
EDA_POLL_INTERVAL=60s

# ── Caddy (optional, Profil: caddy) ───────────────────────────────────────────
# Domain für TLS-Zertifikat via Let's Encrypt
EEG_DOMAIN=meine-eeg.at

# ── Cloudflare Tunnel (optional) ──────────────────────────────────────────────
# Token aus dem Cloudflare Zero Trust Dashboard (Tunnels → Create Tunnel → Token)
# Hostname-Routing wird ausschließlich im Dashboard konfiguriert — nicht im Repo
CLOUDFLARE_TUNNEL_TOKEN=

# Aktive Compose-Profile — kommagetrennt, z.B. cloudflare,eda
# Leer lassen wenn kein optionales Profil benötigt wird.
# COMPOSE_PROFILES=
