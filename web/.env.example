# NextAuth / web app
# Public base URL of the web frontend
NEXTAUTH_URL=http://localhost:3001

# Session encryption secret for NextAuth/Auth.js
NEXTAUTH_SECRET=change-me-in-production

# Some Auth.js setups also read AUTH_SECRET; keep it identical
AUTH_SECRET=change-me-in-production

# Shared JWT secret used by the Go API
JWT_SECRET=change-me-in-production

# Public API URL for local browser access
NEXT_PUBLIC_API_URL=http://localhost:8101

# Internal API URL used by the Next.js server inside Docker
API_INTERNAL_URL=http://eegabrechnung-api:8080
